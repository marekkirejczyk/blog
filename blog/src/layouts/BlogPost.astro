---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  date: Date;
  slug: string;
  description?: string;
  heroImage?: string;
  tags?: string[];
  readMinutes: number;
}

const { title, date, slug, description, heroImage, tags, readMinutes } = Astro.props;

const currentYear = new Date().getFullYear();
const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: date.getFullYear() !== currentYear ? 'numeric' : undefined,
});
---
<BaseLayout title={title} description={description}>
  <article class="post">
    <a class="post__back" href="/">&larr; Back to all posts</a>

    {tags && tags.length > 0 && (
      <div class="post__tags">
        {tags.map((tag) => <span class="post__tag">{tag}</span>)}
      </div>
    )}

    <h1 class="post__title">{title}</h1>

    <div class="post__meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="post__meta-sep">·</span>
      <span>{readMinutes} min read</span>
      {/* Claps — hidden pending backend
      <span class="post__meta-sep">·</span>
      <span class="post__claps">0</span>
      */}
    </div>

    {heroImage && <img class="post__hero" src={heroImage} alt="" loading="lazy" />}

    <div class="post-content">
      <slot />
    </div>

    {/* Action bar — claps / comments count / share — hidden pending backend
    <div class="post__action-bar">
      <button type="button" class="post__action">0 claps</button>
      <button type="button" class="post__action">0 comments</button>
      <span class="post__action-spacer"></span>
      <button type="button" class="post__action">Share</button>
    </div>
    */}
  </article>

  <Comments slug={slug} />

  <script>
    document.querySelectorAll('.post-content a').forEach((a) => {
      if (a instanceof HTMLAnchorElement && a.hostname !== window.location.hostname) {
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener noreferrer');
      }
    });
  </script>
</BaseLayout>

<style>
  .post {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 48px 0 24px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .post__back {
    font-size: 13px;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .post__back:hover {
    color: var(--color-text);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .post__tag {
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    font-size: 12px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }

  .post__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .post__lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 4px;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .post__meta-sep {
    color: var(--color-text-faint);
  }

  .post__claps {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .post__hero {
    width: 100%;
    border-radius: 6px;
    object-fit: cover;
  }

  .post__action-bar {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 16px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .post__action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-surface-muted);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 13px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
  }

  .post__action-spacer {
    flex: 1 0 0;
  }

  /* Rendered markdown content */
  .post-content {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .post-content :global(h2) {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 30px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h3) {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-text-faint);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--color-text);
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-text);
    padding: 8px 0 8px 24px;
    margin: 2rem 0;
    font-style: italic;
    font-size: 22px;
    line-height: 1.5;
    color: var(--color-text);
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .post-content :global(code) {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.88em;
    background: var(--color-surface-muted);
    padding: 0.15em 0.35em;
    border-radius: 3px;
    color: var(--color-text);
  }

  .post-content :global(pre) {
    background: var(--color-code-bg);
    color: var(--color-code-text);
    padding: 18px 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 13px;
    line-height: 1.5;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .post-content :global(img) {
    border-radius: 6px;
    margin: 2rem 0 0.75rem;
  }

  .post-content :global(p:has(> img:only-child)) {
    text-align: center;
  }

  .post-content :global(p:has(> img:only-child) + p) {
    font-style: italic;
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: -0.75rem;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  @media (max-width: 640px) {
    .post {
      padding: 24px 0 16px;
      gap: 18px;
    }

    .post__title {
      letter-spacing: -0.025em;
    }

    .post__lede {
      font-size: 18px;
    }

    .post-content {
      font-size: 17px;
    }

    .post-content :global(h2) {
      font-size: 26px;
    }

    .post-content :global(h3) {
      font-size: 20px;
    }

    .post-content :global(blockquote) {
      font-size: 19px;
      padding-left: 16px;
    }
  }
</style>
