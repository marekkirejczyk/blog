---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Blog by Marek Kirejczyk' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="site-title">zkMarek</a>
        <div class="social-links">
          <a href="https://www.linkedin.com/in/kirejczyk/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/zkmarek" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} zkMarek · <a href="/delete-my-data/">Delete my data</a></p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1rem 1rem;
    border-bottom: 1px solid #eee;
    margin-bottom: 2rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    color: #1a1a1a;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-links a {
    color: #666;
    transition: color 0.2s;
    display: flex;
  }

  .social-links a:hover {
    color: #1a1a1a;
  }

  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .site-footer {
    max-width: 680px;
    margin: 4rem auto 2rem;
    padding: 2rem 1rem 0;
    border-top: 1px solid #eee;
    font-size: 0.85rem;
    color: #999;
  }
</style>
