---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'zkmarek blog' } = Astro.props;
const year = new Date().getFullYear();

const xPath =
  'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z';
const linkedInPath =
  'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/avatar-small.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Source+Serif+Pro:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="brand" aria-label="zkmarek home">
          <img src="/images/avatar-small.png" alt="" class="brand__logo" width="32" height="32" />
          <span class="brand__name">zkmarek</span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {/* <a href="#about" class="site-nav__link">About me</a> */}
          <a
            href="https://x.com/zkmarek"
            class="icon-btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
              <path
                fill="currentColor"
                d={xPath}
              />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/kirejczyk/"
            class="icon-btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
              <path
                fill="currentColor"
                d={linkedInPath}
              />
            </svg>
          </a>
          {/* <a href="#subscribe" class="btn btn--primary btn--compact">Subscribe</a> */}
        </nav>

        <button
          type="button"
          class="burger"
          id="burger-open"
          aria-label="Open menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </header>

    <div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Menu" hidden>
      <div class="mobile-menu__header">
        <a href="/" class="brand">
          <img src="/images/avatar-small.png" alt="" class="brand__logo" width="32" height="32" />
          <span class="brand__name">zkmarek</span>
        </a>
        <button type="button" class="burger" id="burger-close" aria-label="Close menu">
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      </div>
      {/* <nav class="mobile-menu__nav" aria-label="Mobile">
        <a href="#about" class="mobile-menu__link">About me</a>
      </nav> */}
      <div class="mobile-menu__footer">
        <div class="mobile-menu__socials">
          <a
            href="https://x.com/zkmarek"
            class="icon-btn icon-btn--circle"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
              <path
                fill="currentColor"
                d={xPath}
              />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/kirejczyk/"
            class="icon-btn icon-btn--circle"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
              <path
                fill="currentColor"
                d={linkedInPath}
              />
            </svg>
          </a>
          {/* <a href="#subscribe" class="btn btn--primary mobile-menu__subscribe">Subscribe</a> */}
        </div>
        <div class="mobile-menu__links">
          <a href="/privacy/">Privacy Policy</a>
          <a href="/delete-my-data/">Delete my data</a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    {/*
    <section class="subscribe" id="subscribe">
      <div class="subscribe__inner">
        <h2 class="subscribe__title">Never miss a post.</h2>
        <p class="subscribe__blurb">
          Essays on AI, cryptography, software engineering, entrepreneurship, and management
          — delivered only when there's something worth reading.
        </p>
        <form class="subscribe__form" onsubmit="event.preventDefault();">
          <input
            type="email"
            class="subscribe__input"
            placeholder="you@domain.com"
            aria-label="Email address"
          />
          <button type="submit" class="btn btn--primary btn--tall">Subscribe</button>
        </form>
      </div>
    </section>
    */}

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__copy">&copy; {year} zkmarek</p>
        <div class="site-footer__links">
          {/* <a href="#about">About me</a> */}
          <a href="/privacy/">Privacy Policy</a>
          <a href="/delete-my-data/">Delete my data</a>
          <a
            href="https://x.com/zkmarek"
            class="icon-btn icon-btn--small"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
              <path
                fill="currentColor"
                d={xPath}
              />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/kirejczyk/"
            class="icon-btn icon-btn--small"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
              <path
                fill="currentColor"
                d={linkedInPath}
              />
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const menu = document.getElementById('mobile-menu');
        const open = document.getElementById('burger-open');
        const close = document.getElementById('burger-close');
        if (!menu || !open || !close) return;
        const show = () => {
          menu.hidden = false;
          open.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        };
        const hide = () => {
          menu.hidden = true;
          open.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        };
        open.addEventListener('click', show);
        close.addEventListener('click', hide);
        menu.addEventListener('click', (e) => {
          const target = e.target;
          if (target instanceof HTMLAnchorElement) hide();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !menu.hidden) hide();
        });
      })();
    </script>
  </body>
</html>
