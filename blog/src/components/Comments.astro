---
interface Props {
  slug: string;
  apiBase?: string;
}

const defaultApiBase = import.meta.env.PUBLIC_COMMENTS_API;

const { slug, apiBase = defaultApiBase } = Astro.props;
---

<section class="comments-section" data-slug={slug} data-api-base={apiBase}>
  <h2>Comments</h2>

  <div id="auth-bar" class="auth-bar">
    <span class="status">Checking login…</span>
  </div>

  <div id="compose" class="compose" style="display: none;">
    <div id="reply-info" style="display: none;">
      Replying to <span id="reply-parent-name"></span>
      — <a id="cancel-reply">cancel</a>
    </div>
    <textarea id="comment-body" placeholder="Write a comment…"></textarea>
    <button id="post-btn">Post Comment</button>
  </div>

  <div id="comments-list">
    <p class="status">Loading comments…</p>
  </div>
</section>

<script>
  import { esc, renderComment } from '../lib/comments/ui';
  import type { User } from '../lib/comments/ui';
  import {
    fetchCurrentUser,
    fetchProviders,
    fetchComments,
    postComment as apiPostComment,
    deleteComment as apiDeleteComment,
    logout as apiLogout,
  } from '../lib/comments/api';

  const section = document.querySelector('.comments-section')!;
  const slug = section.getAttribute('data-slug')!;
  const apiBase = section.getAttribute('data-api-base')!;

  let currentUser: User | null = null;
  let replyTo: number | null = null;

  const authBar = document.getElementById('auth-bar')!;
  const compose = document.getElementById('compose')! as HTMLElement;
  const commentsList = document.getElementById('comments-list')!;
  const bodyInput = document.getElementById('comment-body')! as HTMLTextAreaElement;
  const replyInfo = document.getElementById('reply-info')! as HTMLElement;
  const replyParentName = document.getElementById('reply-parent-name')!;

  document.getElementById('post-btn')!.addEventListener('click', handlePostComment);
  document.getElementById('cancel-reply')!.addEventListener('click', cancelReply);

  async function checkAuth() {
    try {
      const user = await fetchCurrentUser(apiBase);
      if (user) {
        currentUser = user;
        authBar.innerHTML =
          '<span class="user-info">' +
          (currentUser.avatar_url
            ? '<img src="' + esc(currentUser.avatar_url) + '" class="avatar" alt="" />'
            : '') +
          '<span>' + esc(currentUser.name) + '</span>' +
          (currentUser.is_admin ? '<span class="admin-badge">admin</span>' : '') +
          '</span>' +
          '<a id="logout-btn" class="auth-link">Logout</a>';
        document.getElementById('logout-btn')!.addEventListener('click', handleLogout);
        compose.style.display = 'block';
      } else {
        showLoginButtons();
      }
    } catch {
      showLoginButtons();
    }
  }

  async function showLoginButtons() {
    try {
      const providers = await fetchProviders(apiBase);
      if (providers.length > 0) {
        const currentPage = window.location.href;
        const buttons = providers.map(function(p) {
          const label = p.charAt(0).toUpperCase() + p.slice(1);
          return '<a href="' + apiBase + '/auth/' + p + '?redirect=' + encodeURIComponent(currentPage) + '" class="login-btn login-' + p + '">' + label + '</a>';
        }).join(' ');
        authBar.innerHTML = '<span>Sign in with </span>' + buttons + '<span class="privacy-note">By signing in, you agree to our <a href="/privacy/">Privacy Policy</a>.</span>';
      } else {
        authBar.innerHTML = '<span class="status">Comments require login (no providers configured)</span>';
      }
    } catch {
      authBar.innerHTML = '<span class="status">Could not load login options</span>';
    }
  }

  async function handleLogout() {
    await apiLogout(apiBase);
    currentUser = null;
    compose.style.display = 'none';
    cancelReply();
    showLoginButtons();
  }

  async function loadComments() {
    try {
      const comments = await fetchComments(apiBase, slug);
      if (comments.length === 0) {
        commentsList.innerHTML = '<p class="status">No comments yet. Be the first!</p>';
        return;
      }
      commentsList.innerHTML = comments.map((c) => renderComment(c, currentUser)).join('');
      attachCommentListeners();
    } catch {
      commentsList.innerHTML = '<p class="status">Could not load comments.</p>';
    }
  }

  function attachCommentListeners() {
    commentsList.querySelectorAll('.reply-btn').forEach(function(btn) {
      const el = btn as HTMLElement;
      el.addEventListener('click', function() {
        startReply(parseInt(el.dataset.id!), el.dataset.name!);
      });
    });
    commentsList.querySelectorAll('.delete-btn').forEach(function(btn) {
      const el = btn as HTMLElement;
      el.addEventListener('click', function() {
        handleDeleteComment(parseInt(el.dataset.id!));
      });
    });
  }

  function startReply(id: number, name: string) {
    replyTo = id;
    replyParentName.textContent = name;
    replyInfo.style.display = 'block';
    bodyInput.focus();
  }

  function cancelReply() {
    replyTo = null;
    replyInfo.style.display = 'none';
  }

  async function handlePostComment() {
    const body = bodyInput.value.trim();
    if (!body) return;

    try {
      await apiPostComment(apiBase, slug, body, replyTo ?? undefined);
      bodyInput.value = '';
      cancelReply();
      loadComments();
    } catch (e) {
      alert('Error: ' + (e instanceof Error ? e.message : 'Could not post comment.'));
    }
  }

  async function handleDeleteComment(id: number) {
    if (!confirm('Delete this comment?')) return;
    try {
      await apiDeleteComment(apiBase, id);
      loadComments();
    } catch (e) {
      alert('Error: ' + (e instanceof Error ? e.message : 'Could not delete comment.'));
    }
  }

  checkAuth();
  loadComments();
</script>

<style>
  /* Section */
  .comments-section {
    border-top: 1px solid #e6e6e6;
    margin-top: 3rem;
    padding-top: 2rem;
  }

  .comments-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1.25rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* Auth bar */
  .auth-bar {
    font-size: 0.9rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  #auth-bar :global(.user-info) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #auth-bar :global(.avatar) {
    width: 24px;
    height: 24px;
    border-radius: 50%;
  }

  #auth-bar :global(.auth-link) {
    color: #757575;
    cursor: pointer;
    font-size: 0.85rem;
    text-decoration: underline;
    text-decoration-color: #bbb;
    text-underline-offset: 2px;
  }

  #auth-bar :global(.auth-link:hover) {
    text-decoration-color: #1a1a1a;
    color: #1a1a1a;
  }

  #auth-bar :global(.admin-badge) {
    font-size: 0.7rem;
    color: #856404;
    background: #fff3cd;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    margin-left: 0.25rem;
  }

  #auth-bar :global(.login-btn) {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border: 1px solid #ddd;
    border-radius: 20px;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 0.85rem;
    transition: border-color 0.15s, background 0.15s;
  }

  #auth-bar :global(.login-btn:hover) {
    border-color: #1a1a1a;
    background: #fafafa;
  }

  #auth-bar :global(.privacy-note) {
    display: block;
    width: 100%;
    font-size: 0.78rem;
    color: #999;
    margin-top: 0.25rem;
  }

  #auth-bar :global(.privacy-note a) {
    color: #999;
    text-decoration: underline;
    text-decoration-color: #ccc;
    text-underline-offset: 2px;
  }

  #auth-bar :global(.privacy-note a:hover) {
    color: #666;
    text-decoration-color: #666;
  }

  /* Compose */
  .compose {
    margin-bottom: 1.75rem;
  }

  #reply-info {
    font-size: 0.85rem;
    color: #757575;
    margin-bottom: 0.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  #cancel-reply {
    color: #757575;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: #bbb;
    text-underline-offset: 2px;
  }

  #cancel-reply:hover {
    text-decoration-color: #1a1a1a;
    color: #1a1a1a;
  }

  textarea {
    width: 100%;
    min-height: 100px;
    padding: 0.75rem;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 0.95rem;
    resize: vertical;
    margin-bottom: 0.5rem;
    line-height: 1.6;
    transition: border-color 0.15s;
  }

  textarea:focus {
    outline: none;
    border-color: #999;
  }

  button {
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 0.5rem 1.25rem;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    transition: background 0.15s;
  }

  button:hover {
    background: #333;
  }

  .status {
    color: #999;
    font-style: italic;
    font-size: 0.9rem;
  }

  /* Comment — use :global() since these are JS-generated */
  #comments-list :global(.comment) {
    padding: 1.25rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  #comments-list :global(.comment:last-child) {
    border-bottom: none;
  }

  #comments-list :global(.comment-meta) {
    font-size: 0.85rem;
    color: #757575;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #comments-list :global(.comment-meta strong) {
    color: #1a1a1a;
    font-weight: 600;
  }

  #comments-list :global(.comment-author) {
    color: inherit;
    text-decoration: none;
  }

  #comments-list :global(.comment-author:hover strong) {
    text-decoration: underline;
  }

  #comments-list :global(.comment-time) {
    color: #999;
  }

  /* Avatar */
  #comments-list :global(.avatar) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  #comments-list :global(.avatar-placeholder) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #e0e0e0;
    color: #757575;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* Comment body */
  #comments-list :global(.comment-body) {
    margin: 0.25rem 0 0.5rem;
    line-height: 1.6;
  }

  #comments-list :global(.comment-body p) {
    margin: 0 0 0.5em;
  }

  #comments-list :global(.comment-body p:last-child) {
    margin-bottom: 0;
  }

  #comments-list :global(.comment-body a) {
    color: #1a73e8;
    text-decoration: underline;
    text-decoration-color: #a8c7fa;
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s;
  }

  #comments-list :global(.comment-body a:hover) {
    text-decoration-color: #1a73e8;
  }

  #comments-list :global(.comment-body code) {
    background: #f5f5f5;
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  #comments-list :global(.comment-body pre) {
    background: #f5f5f5;
    padding: 0.75em 1em;
    border-radius: 4px;
    overflow-x: auto;
    margin: 0.5em 0;
  }

  #comments-list :global(.comment-body pre code) {
    background: none;
    padding: 0;
  }

  #comments-list :global(.comment-body blockquote) {
    border-left: 3px solid #e0e0e0;
    margin: 0.5em 0;
    padding: 0.25em 0 0.25em 1em;
    color: #555;
  }

  #comments-list :global(.comment-body ul),
  #comments-list :global(.comment-body ol) {
    margin: 0.5em 0;
    padding-left: 1.5em;
  }

  /* Actions */
  #comments-list :global(.comment-actions) {
    font-size: 0.8rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  #comments-list :global(.comment-actions a) {
    color: #757575;
    cursor: pointer;
    margin-right: 1rem;
    text-decoration: underline;
    text-decoration-color: #ccc;
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s;
  }

  #comments-list :global(.comment-actions a:hover) {
    text-decoration-color: #1a1a1a;
    color: #1a1a1a;
  }

  /* Replies */
  #comments-list :global(.replies) {
    margin-left: 2rem;
    border-left: 2px solid #f0f0f0;
    padding-left: 1rem;
  }

  #comments-list :global(.replies .comment) {
    border-bottom: none;
    padding: 1rem 0 0;
  }

  #comments-list :global(.replies .comment:last-child) {
    padding-bottom: 0;
  }
</style>
