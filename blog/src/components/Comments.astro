---
interface Props {
  slug: string;
  apiBase?: string;
}

const defaultApiBase = import.meta.env.PUBLIC_COMMENTS_API;

const { slug, apiBase = defaultApiBase } = Astro.props;
---

<section class="comments-section" data-slug={slug} data-api-base={apiBase}>
  <h2 class="comments-heading">Comments</h2>

  <div id="auth-bar" class="auth-bar">
    <span class="status">Checking login…</span>
  </div>

  <div id="compose" class="compose" style="display: none;">
    <textarea id="comment-body" placeholder="Write a comment…"></textarea>
    <button id="post-btn" class="btn-post">Post Comment</button>
  </div>

  <div class="comments-divider"></div>

  <div id="comments-list">
    <p class="status">Loading comments…</p>
  </div>
</section>

<script>
  import { esc, renderComment } from '../lib/comments/ui';
  import type { User } from '../lib/comments/ui';
  import {
    fetchCurrentUser,
    fetchProviders,
    fetchComments,
    postComment as apiPostComment,
    deleteComment as apiDeleteComment,
    logout as apiLogout,
  } from '../lib/comments/api';

  const section = document.querySelector('.comments-section')!;
  const slug = section.getAttribute('data-slug')!;
  const apiBase = section.getAttribute('data-api-base')!;

  let currentUser: User | null = null;

  const authBar = document.getElementById('auth-bar')!;
  const compose = document.getElementById('compose')! as HTMLElement;
  const commentsList = document.getElementById('comments-list')!;
  const bodyInput = document.getElementById('comment-body')! as HTMLTextAreaElement;

  document.getElementById('post-btn')!.addEventListener('click', () => postTopLevelComment());

  async function checkAuth() {
    try {
      const user = await fetchCurrentUser(apiBase);
      if (user) {
        currentUser = user;
        authBar.innerHTML =
          '<div class="user-row">' +
            '<span class="user-info">' +
              (currentUser.avatar_url
                ? '<img src="' + esc(currentUser.avatar_url) + '" class="avatar" alt="" />'
                : '<span class="avatar-placeholder">' + esc((currentUser.name || '?').charAt(0).toUpperCase()) + '</span>') +
              '<span class="user-name">' + esc(currentUser.name) + '</span>' +
              (currentUser.is_admin ? '<span class="admin-badge">admin</span>' : '') +
            '</span>' +
            '<a id="logout-btn" class="auth-link">Logout</a>' +
          '</div>';
        document.getElementById('logout-btn')!.addEventListener('click', handleLogout);
        compose.style.display = 'block';
      } else {
        showLoginButtons();
      }
    } catch {
      showLoginButtons();
    }
  }

  async function showLoginButtons() {
    try {
      const providers = await fetchProviders(apiBase);
      if (providers.length > 0) {
        const currentPage = window.location.href;
        var providerIcons = {
          github: '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>',
          google: '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M15.545 6.558a9.4 9.4 0 01.139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 018 0a7.689 7.689 0 015.352 2.082l-2.284 2.284A4.347 4.347 0 008 3.166c-2.087 0-3.86 1.408-4.492 3.304a4.79 4.79 0 000 3.063h.003c.635 1.893 2.405 3.301 4.492 3.301 1.078 0 2.004-.276 2.722-.764h-.003a3.702 3.702 0 001.599-2.431H8V6.558h7.545z"/></svg>',
          facebook: '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0 0 3.603 0 8.05 0 12.07 2.925 15.43 6.75 16v-5.624H4.718V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.571 6.75-3.93 6.75-7.951z"/></svg>',
          linkedin: '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>',
          x: '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633z"/></svg>'
        };
        const buttons = providers.map(function(p) {
          const label = p.charAt(0).toUpperCase() + p.slice(1);
          const icon = providerIcons[p] || '';
          return '<a href="' + apiBase + '/auth/' + p + '?redirect=' + encodeURIComponent(currentPage) + '" class="login-btn login-' + p + '">' + icon + label + '</a>';
        }).join('');
        authBar.innerHTML =
          '<div class="login-card">' +
            '<h3 class="login-title">Join the conversation</h3>' +
            '<p class="login-blurb">Sign in to post a comment. We never spam, and your email stays private.</p>' +
            '<p class="login-label">Sign in with:</p>' +
            '<div class="login-buttons">' + buttons + '</div>' +
            '<p class="privacy-note">By signing in, you agree to our <a href="/privacy/">Privacy Policy</a>.</p>' +
          '</div>';
      } else {
        authBar.innerHTML = '<span class="status">Comments require login (no providers configured)</span>';
      }
    } catch {
      authBar.innerHTML = '<span class="status">Could not load login options</span>';
    }
  }

  async function handleLogout() {
    await apiLogout(apiBase);
    currentUser = null;
    compose.style.display = 'none';
    closeInlineReply();
    showLoginButtons();
  }

  async function loadComments() {
    try {
      const comments = await fetchComments(apiBase, slug);
      if (comments.length === 0) {
        commentsList.innerHTML = '<p class="status">No comments yet. Be the first!</p>';
        return;
      }
      commentsList.innerHTML = comments.map((c) => renderComment(c, currentUser)).join('');
      attachCommentListeners();
    } catch {
      commentsList.innerHTML = '<p class="status">Could not load comments.</p>';
    }
  }

  function attachCommentListeners() {
    commentsList.querySelectorAll('.reply-btn').forEach(function(btn) {
      const el = btn as HTMLElement;
      el.addEventListener('click', function() {
        openInlineReply(parseInt(el.dataset.id!), el.dataset.name!, el);
      });
    });
    commentsList.querySelectorAll('.delete-btn').forEach(function(btn) {
      const el = btn as HTMLElement;
      el.addEventListener('click', function() {
        handleDeleteComment(parseInt(el.dataset.id!));
      });
    });
  }

  function closeInlineReply() {
    document.querySelector('#comments-list .reply-form')?.remove();
  }

  function openInlineReply(parentId: number, parentName: string, replyBtn: HTMLElement) {
    if (!currentUser) return;
    closeInlineReply();

    const comment = replyBtn.closest('.comment') as HTMLElement | null;
    const actions = replyBtn.closest('.comment-actions') as HTMLElement | null;
    if (!comment || !actions) return;

    const avatarHtml = currentUser.avatar_url
      ? '<img src="' + esc(currentUser.avatar_url) + '" class="avatar" alt="" />'
      : '<span class="avatar-placeholder">' + esc((currentUser.name || '?').charAt(0).toUpperCase()) + '</span>';

    const form = document.createElement('div');
    form.className = 'reply-form';
    form.innerHTML =
      '<div class="reply-info">' +
        'Replying to <strong>' + esc(parentName) + '</strong>' +
        '<span class="sep">·</span>' +
        '<a class="cancel-reply">cancel</a>' +
      '</div>' +
      '<div class="reply-user">' + avatarHtml + '<span class="user-name">' + esc(currentUser.name) + '</span></div>' +
      '<textarea class="reply-body" placeholder="Write a comment…"></textarea>' +
      '<div class="reply-actions">' +
        '<button type="button" class="btn-cancel">Cancel</button>' +
        '<button type="button" class="btn-post">Post Reply</button>' +
      '</div>';

    actions.after(form);

    const textarea = form.querySelector('.reply-body') as HTMLTextAreaElement;
    form.querySelector('.cancel-reply')!.addEventListener('click', closeInlineReply);
    form.querySelector('.btn-cancel')!.addEventListener('click', closeInlineReply);
    form.querySelector('.btn-post')!.addEventListener('click', () => postReply(parentId, textarea));

    textarea.focus();
  }

  async function postTopLevelComment() {
    const body = bodyInput.value.trim();
    if (!body) return;
    try {
      await apiPostComment(apiBase, slug, body);
      bodyInput.value = '';
      loadComments();
    } catch (e) {
      alert('Error: ' + (e instanceof Error ? e.message : 'Could not post comment.'));
    }
  }

  async function postReply(parentId: number, textarea: HTMLTextAreaElement) {
    const body = textarea.value.trim();
    if (!body) return;
    try {
      await apiPostComment(apiBase, slug, body, parentId);
      closeInlineReply();
      loadComments();
    } catch (e) {
      alert('Error: ' + (e instanceof Error ? e.message : 'Could not post comment.'));
    }
  }

  async function handleDeleteComment(id: number) {
    if (!confirm('Delete this comment?')) return;
    try {
      await apiDeleteComment(apiBase, id);
      loadComments();
    } catch (e) {
      alert('Error: ' + (e instanceof Error ? e.message : 'Could not delete comment.'));
    }
  }

  checkAuth();
  loadComments();
</script>

<style>
  .comments-section {
    max-width: var(--content-max);
    margin: 40px auto 48px;
    padding: 0 0;
    font-family: var(--font-sans);
  }

  .comments-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.26px;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  /* Auth bar — generic container */
  .auth-bar {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }

  /* Logged-in user row */
  #auth-bar :global(.user-row) {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #auth-bar :global(.user-info) {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1 0 0;
  }

  #auth-bar :global(.user-name) {
    font-weight: 500;
    color: var(--color-text);
    font-size: 14px;
  }

  #auth-bar :global(.avatar) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  #auth-bar :global(.avatar-placeholder) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }

  #auth-bar :global(.auth-link) {
    color: var(--color-text-muted);
    font-size: 13px;
    cursor: pointer;
  }

  #auth-bar :global(.auth-link:hover) {
    color: var(--color-text);
  }

  #auth-bar :global(.admin-badge) {
    font-size: 11px;
    color: #856404;
    background: #fff3cd;
    padding: 1px 6px;
    border-radius: 3px;
    margin-left: 4px;
  }

  /* Logged-out card */
  #auth-bar :global(.login-card) {
    background: var(--color-surface-muted);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
    text-align: center;
  }

  #auth-bar :global(.login-title) {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-text);
    margin: 0;
  }

  #auth-bar :global(.login-blurb) {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 420px;
  }

  #auth-bar :global(.login-label) {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 6px 0 0;
  }

  #auth-bar :global(.login-buttons) {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  #auth-bar :global(.login-btn) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-text);
    font-size: 14px;
    font-weight: 500;
    transition: border-color 0.15s, background 0.15s;
  }

  #auth-bar :global(.login-btn svg) {
    width: 14px;
    height: 14px;
    color: var(--color-accent);
  }

  #auth-bar :global(.login-btn:hover) {
    border-color: var(--color-text);
  }

  #auth-bar :global(.privacy-note) {
    font-size: 12px;
    color: var(--color-text-faint);
    margin: 6px 0 0;
  }

  #auth-bar :global(.privacy-note a) {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-text-faint);
    text-underline-offset: 2px;
  }

  #auth-bar :global(.privacy-note a:hover) {
    color: var(--color-text);
  }

  /* Compose */
  .compose {
    margin-bottom: 8px;
  }

  /* Inline reply form injected under a comment */
  #comments-list :global(.reply-form) {
    margin: 12px 0 8px;
    padding: 14px 16px;
    background: var(--color-surface-muted);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #comments-list :global(.reply-form .reply-info) {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  #comments-list :global(.reply-form .reply-info strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  #comments-list :global(.reply-form .reply-info .sep) {
    color: var(--color-text-faint);
    margin: 0 6px;
  }

  #comments-list :global(.reply-form .cancel-reply) {
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--color-text-faint);
    text-underline-offset: 2px;
  }

  #comments-list :global(.reply-form .cancel-reply:hover) {
    color: var(--color-text);
    text-decoration-color: var(--color-text);
  }

  #comments-list :global(.reply-form .reply-user) {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #comments-list :global(.reply-form .reply-user .user-name) {
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text);
  }

  #comments-list :global(.reply-form .reply-body) {
    margin-bottom: 0;
  }

  #comments-list :global(.reply-form .reply-actions) {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  #comments-list :global(.reply-form .btn-cancel) {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 12px 20px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    transition: border-color 0.15s;
  }

  #comments-list :global(.reply-form .btn-cancel:hover) {
    border-color: var(--color-text);
  }

  #comments-list :global(.reply-form .btn-post) {
    background: var(--color-accent);
    color: #fff;
    border: none;
    padding: 12px 20px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    transition: background 0.15s;
  }

  #comments-list :global(.reply-form .btn-post:hover) {
    background: var(--color-accent-hover);
  }

  .comments-section :global(textarea) {
    display: block;
    width: 100%;
    min-height: 110px;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-text);
    background: var(--color-surface);
    resize: vertical;
    margin-bottom: 14px;
    transition: border-color 0.15s;
  }

  .comments-section :global(textarea::placeholder) {
    color: var(--color-text-faint);
  }

  .comments-section :global(textarea:focus) {
    outline: none;
    border-color: var(--color-text);
  }

  .btn-post {
    background: var(--color-accent);
    color: #fff;
    border: none;
    padding: 12px 20px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .btn-post:hover {
    background: var(--color-accent-hover);
  }

  .comments-divider {
    height: 1px;
    background: var(--color-border);
    margin: 24px 0;
  }

  .status {
    color: var(--color-text-muted);
    font-size: 14px;
  }

  /* Comment items — JS-generated, so :global() scopes */
  #comments-list :global(.comment) {
    padding: 16px 0;
  }

  #comments-list :global(.comment + .comment) {
    border-top: 1px solid var(--color-border);
  }

  #comments-list :global(.comment-meta) {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  #comments-list :global(.comment-meta strong) {
    color: var(--color-text);
    font-weight: 600;
    font-size: 14px;
  }

  #comments-list :global(.comment-author) {
    color: inherit;
    text-decoration: none;
  }

  #comments-list :global(.comment-author:hover strong) {
    text-decoration: underline;
  }

  #comments-list :global(.comment-time) {
    color: var(--color-text-muted);
  }

  #comments-list :global(.avatar) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  #comments-list :global(.avatar-placeholder) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }

  #comments-list :global(.comment-body) {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 4px 0 10px;
  }

  #comments-list :global(.comment-body p) {
    margin: 0 0 0.6em;
  }

  #comments-list :global(.comment-body p:last-child) {
    margin-bottom: 0;
  }

  #comments-list :global(.comment-body a) {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-text-faint);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s;
  }

  #comments-list :global(.comment-body a:hover) {
    text-decoration-color: var(--color-text);
  }

  #comments-list :global(.comment-body code) {
    background: var(--color-surface-muted);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  #comments-list :global(.comment-body pre) {
    background: var(--color-code-bg);
    color: var(--color-code-text);
    padding: 14px 16px;
    border-radius: 6px;
    overflow-x: auto;
    margin: 0.5em 0;
    font-size: 13px;
  }

  #comments-list :global(.comment-body pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  #comments-list :global(.comment-body blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 0.5em 0;
    padding: 0.25em 0 0.25em 14px;
    color: var(--color-text-muted);
  }

  #comments-list :global(.comment-body ul),
  #comments-list :global(.comment-body ol) {
    margin: 0.5em 0;
    padding-left: 1.5em;
  }

  #comments-list :global(.comment-actions) {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
  }

  #comments-list :global(.comment-actions a) {
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s;
  }

  #comments-list :global(.comment-actions a:hover) {
    color: var(--color-text);
  }

  #comments-list :global(.replies) {
    margin-left: 38px;
    margin-top: 8px;
    padding-left: 14px;
    border-left: 1px solid var(--color-border);
  }

  #comments-list :global(.replies .comment) {
    padding: 10px 0;
  }

  #comments-list :global(.replies .comment + .comment) {
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .comments-heading {
      font-size: 22px;
    }

    #auth-bar :global(.login-card) {
