---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const currentYear = new Date().getFullYear();
const shortDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: d.getFullYear() !== currentYear ? 'numeric' : undefined,
  });
---
<BaseLayout title="zkmarek">
  <section class="post-list" aria-label="Posts">
    {posts.map((post) => (
      <article class="post-card">
        <a class="post-card__link" href={`/blog/${post.id.replace(/\.md$/, '')}/`}>
          <div class="post-card__text">
            <h2 class="post-card__title">{post.data.title}</h2>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-card__tags">
                {post.data.tags.map((tag) => <span class="post-card__tag">{tag}</span>)}
              </div>
            )}
            {post.data.description && (
              <p class="post-card__excerpt">{post.data.description}</p>
            )}
            <div class="post-card__meta">
              <time datetime={post.data.date.toISOString()}>{shortDate(post.data.date)}</time>
            </div>
          </div>
          {post.data.heroImage && (
            <div class="post-card__cover-wrap">
              <img class="post-card__cover" src={post.data.heroImage} alt="" loading="lazy" />
            </div>
          )}
        </a>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .post-list {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 24px 0;
  }

  .post-card {
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: 0;
  }

  .post-card__link {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    padding: 20px 0;
  }

  .post-card__text {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-card__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: -0.22px;
    color: var(--color-text-strong);
    transition: color 0.15s;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-text-muted);
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 8px;
  }

  .post-card__tag {
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    font-size: 12px;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .post-card__excerpt {
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 4px;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .post-card__cover-wrap {
    flex-shrink: 0;
    width: 240px;
    height: 160px;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-placeholder);
  }

  .post-card__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Tablet: keep side-by-side, tighter gap */
  @media (max-width: 1023px) {
    .post-list {
      padding: 16px 0;
    }
    .post-card__link {
      gap: 24px;
    }
    .post-card__cover-wrap {
      width: 200px;
      height: 134px;
    }
  }

  /* Mobile: stack cover on top, full-width, then text */
  @media (max-width: 640px) {
    .post-card__link {
      flex-direction: column;
      gap: 16px;
      padding: 24px 0;
    }
    .post-card__cover-wrap {
      order: -1;
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 10;
    }
    .post-card__title {
      font-size: 20px;
    }
    .post-card__excerpt {
      font-size: 14.5px;
    }
  }
</style>
