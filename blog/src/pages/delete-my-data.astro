---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Delete My Data" description="How to request deletion of your data">
  <article class="page-content">
    <h1>Delete my data</h1>
    <p>
      To request deletion of your data, please email me at
      <a href="mailto:hello@zkmarek.com"><span style="unicode-bidi: bidi-override; direction: rtl;">moc.keramkz@olleh</span>
</a>.
      I will remove all your information within 30 days.
    </p>
  </article>
</BaseLayout>

<style>
  .page-content {
    padding: 1rem 0;
  }

  .page-content h1 {
    margin-bottom: 1.5rem;
  }
</style>
