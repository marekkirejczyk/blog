---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Blog by Marek Kirejczyk' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="site-title">zkMarek</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} zkMarek</p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1rem 1rem;
    border-bottom: 1px solid #eee;
    margin-bottom: 2rem;
  }

  .site-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    color: #1a1a1a;
  }

  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .site-footer {
    max-width: 680px;
    margin: 4rem auto 2rem;
    padding: 2rem 1rem 0;
    border-top: 1px solid #eee;
    font-size: 0.85rem;
    color: #999;
  }
</style>
