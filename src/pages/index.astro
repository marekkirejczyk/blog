---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout title="Marek Kirejczyk">
  <section class="post-list">
    {posts.map((post) => {
      const formattedDate = post.data.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
      return (
        <article class="post-item">
          <a href={`/blog/${post.id.replace(/\.md$/, '')}/`}>
            {post.data.heroImage && <img class="post-cover" src={post.data.heroImage} alt="" />}
            <div class="post-text">
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              <h2>{post.data.title}</h2>
              {post.data.description && <p>{post.data.description}</p>}
            </div>
          </a>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .post-list {
    padding: 1rem 0;
  }

  .post-item {
    margin-bottom: 2.5rem;
  }

  .post-item a {
    text-decoration: none;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .post-cover {
    width: 200px;
    height: 134px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .post-text {
    flex: 1;
    min-width: 0;
  }

  .post-item a:hover h2 {
    color: #555;
  }

  .post-item time {
    font-size: 0.85rem;
    color: #999;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  .post-item h2 {
    font-size: 1.5rem;
    margin-top: 0.25rem;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .post-item p {
    color: #555;
    font-size: 0.95rem;
    margin-top: 0.25rem;
    line-height: 1.5;
  }
</style>
